# Culina Docker Compose 部署配置示例。
# 部署前复制为 deploy/.env。MYSQL_HOST、MINIO_ENDPOINT、QDRANT_URL 等内部服务地址
# 固定在 docker-compose.yml 中，不需要也不应该在这里让部署用户修改。

# 宿主机访问与前端构建
FRONTEND_PORT=8080
FRONTEND_ORIGIN=http://localhost:8080
# 浏览器通过前端 nginx 的 /api 代理访问后端时保持为空。
VITE_API_BASE_URL=
TZ=Asia/Shanghai

# 构建下载镜像
PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple
NPM_CONFIG_REGISTRY=https://registry.npmmirror.com

# 后端运行与安全。ENVIRONMENT 常用 local/development/dev/test/testing；其他值按非本地环境做安全校验。
# 非本地部署前必须替换 secret。
ENVIRONMENT=local
LOG_LEVEL=INFO
JWT_SECRET=culina-local-dev-secret
ACCESS_TOKEN_EXPIRE_MINUTES=10080
MEDIA_MAX_UPLOAD_BYTES=31457280

# 数据库凭据与可选宿主机端口。后端容器内部固定连接 mysql:3306。
MYSQL_PORT=3306
MYSQL_DATABASE=culina
MYSQL_USER=culina
MYSQL_PASSWORD=culina_local_password
MYSQL_ROOT_PASSWORD=culina_local_root

# MinIO 凭据与可选宿主机端口。后端容器内部固定连接 minio:9000。
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=culina
MINIO_ROOT_PASSWORD=culina_local_minio_secret
MINIO_BUCKET=culina-media

# 初始家庭引导。仅在数据库没有任何用户时生效。
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=CulinaAdmin123!
INITIAL_ADMIN_DISPLAY_NAME=家庭管理员
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PHONE=
INITIAL_FAMILY_NAME=Culina 家庭厨房
INITIAL_FAMILY_MOTTO=
INITIAL_FAMILY_LOCATION=

# 对话模型。AI_PROVIDER 可选：
# - disabled/mock：不启用对话 AI。
# - openai/openai-compatible/compatible/custom/dashscope：走 OpenAI Chat Completions 兼容接口。
# - responses/openai-responses/openai-response：走 OpenAI Responses API。
AI_PROVIDER=disabled
AI_API_BASE=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=
AI_SUPPORTS_VISION=true
AI_TIMEOUT_SECONDS=180
AI_PROMPT_CACHE_ENABLED=true

# AI 追踪与可观测性。除可信本地排查外，payload 建议保持 redacted。
AI_TRACE_ENABLED=true
AI_TRACE_CAPTURE_LLM_EXCHANGES=false
AI_TRACE_CAPTURE_MESSAGE_CONTENT=false
AI_TRACE_CAPTURE_STREAM_CHUNKS=false
AI_TRACE_CAPTURE_IMAGE_BYTES=false
AI_TRACE_PAYLOAD_MODE=redacted
AI_TRACE_RETENTION_DAYS=7
AI_TRACE_MAX_REQUEST_BYTES=1048576
AI_TRACE_MAX_RESPONSE_BYTES=1048576

# AI 音频、语音识别、语音合成和实时语音。AI_STT/TTS/REALTIME_PROVIDER 可选 disabled/mock、openai、dashscope。
# AI_AUDIO_ENABLED=false 时整体关闭语音能力。
AI_AUDIO_ENABLED=false
AI_STT_PROVIDER=disabled
AI_STT_API_BASE=
AI_STT_API_KEY=
AI_STT_MODEL=
AI_STT_LANGUAGE_HINT=zh
AI_STT_AUDIO_FORMAT=auto
AI_STT_SAMPLE_RATE=16000
AI_STT_HOTWORDS=
AI_STT_TIMEOUT_SECONDS=45
AI_STT_MAX_UPLOAD_BYTES=10485760
AI_STT_MAX_DURATION_SECONDS=60
AI_TTS_PROVIDER=disabled
AI_TTS_API_BASE=
AI_TTS_API_KEY=
AI_TTS_MODEL=
AI_TTS_VOICE=
AI_TTS_FORMAT=mp3
AI_TTS_SAMPLE_RATE=24000
AI_TTS_LANGUAGE_TYPE=Chinese
AI_TTS_STREAMING=false
AI_TTS_TIMEOUT_SECONDS=45
AI_REALTIME_PROVIDER=disabled
AI_REALTIME_API_BASE=
AI_REALTIME_API_KEY=
AI_REALTIME_MODEL=
AI_REALTIME_VOICE=
AI_REALTIME_AUDIO_FORMAT=pcm
AI_REALTIME_INPUT_SAMPLE_RATE=16000
AI_REALTIME_OUTPUT_SAMPLE_RATE=24000
AI_REALTIME_VAD_SILENCE_MS=400
AI_REALTIME_TIMEOUT_SECONDS=300

# DashScope 共享凭据。上方各 provider 的专用 key 可覆盖这里。
DASHSCOPE_API_KEY=
DASHSCOPE_WORKSPACE_ID=
DASHSCOPE_REGION=cn-beijing
DASHSCOPE_HTTP_API_BASE=
DASHSCOPE_WEBSOCKET_API_BASE=

# AI 图片生成。AI_IMAGE_*_PROVIDER 可选 disabled/mock、dashscope、openai/openai-compatible/compatible/custom。
# 默认示例使用 DashScope。
AI_IMAGE_REFERENCE_PROVIDER=disabled
AI_IMAGE_REFERENCE_API_BASE=https://dashscope.aliyuncs.com/api/v1
AI_IMAGE_REFERENCE_API_KEY=
AI_IMAGE_REFERENCE_MODEL=wan2.6-image
AI_IMAGE_TEXT_PROVIDER=disabled
AI_IMAGE_TEXT_API_BASE=https://dashscope.aliyuncs.com/api/v1
AI_IMAGE_TEXT_API_KEY=
AI_IMAGE_TEXT_MODEL=wan2.6-t2i

# 搜索。Qdrant 内部地址固定在 compose；QDRANT_PORT 只控制宿主机端口暴露。
# SEARCH_EMBEDDING_PROVIDER 可选 disabled/mock、openai、openai-compatible、dashscope。
# SEARCH_RERANK_PROVIDER 可选 disabled/mock、openai/openai-compatible/compatible/custom、dashscope、cohere、jina。
QDRANT_PORT=6333
SEARCH_HYBRID_ENABLED=true
SEARCH_EMBEDDING_PROVIDER=disabled
SEARCH_EMBEDDING_API_BASE=
SEARCH_EMBEDDING_API_KEY=
SEARCH_EMBEDDING_MODEL=
SEARCH_EMBEDDING_DIMENSIONS=0
SEARCH_EMBEDDING_TIMEOUT_SECONDS=30
SEARCH_RERANK_PROVIDER=disabled
SEARCH_RERANK_API_BASE=
SEARCH_RERANK_API_KEY=
SEARCH_RERANK_MODEL=
SEARCH_RERANK_TIMEOUT_SECONDS=10
SEARCH_RERANK_INSTRUCT=你是中文厨房搜索结果重排器。目标是找出与查询词最直接匹配的食材、食物或菜谱。短查询优先按字面匹配排序：名称完全相同 > 名称、别名或关键词包含查询词 > 语义相关但未字面命中 > 无关、测试或占位数据。不要因为分类、详情或语义描述泛泛相关，就把未字面命中的记录排到字面命中记录前面。
SEARCH_RERANK_SEMANTIC_MIN_SCORE=0.48
SEARCH_RERANK_MIN_SCORE=0.58
SEARCH_LITERAL_FALLBACK_MIN_SCORE=0.70
SEARCH_RERANK_CANDIDATE_LIMIT=50
QDRANT_API_KEY=
QDRANT_COLLECTION=culina_search
QDRANT_TIMEOUT_SECONDS=10
